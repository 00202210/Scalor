local Config = {}

local DEFAULT_MAX_SUFFIX_POWER = 1001
local MAX_SUFFIX_POWER_LIMIT = 1001

Config.MAX_SUFFIX_POWER = DEFAULT_MAX_SUFFIX_POWER

Config.MAX_ADD_DIFF = 10
Config.MAX_SAFE_INTEGER = 9007199254740991

local MAX_SUFFIX_POWER = Config.MAX_SUFFIX_POWER
if type(MAX_SUFFIX_POWER) ~= "number" or math.isnan(MAX_SUFFIX_POWER) or math.isinf(MAX_SUFFIX_POWER) then
	MAX_SUFFIX_POWER = DEFAULT_MAX_SUFFIX_POWER
end

Config.MAX_SUFFIX_POWER = math.clamp(MAX_SUFFIX_POWER // 1, 1, MAX_SUFFIX_POWER_LIMIT)

return Config
